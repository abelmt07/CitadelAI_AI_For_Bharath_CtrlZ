# Citadel AI – Environment Variables Example
# Copy this file to .env and fill in your actual values
# DO NOT commit .env files to git (they are in .gitignore)

# ========================================
# AWS CONFIGURATION
# ========================================

# AWS Region (us-east-1 for our deployment)
AWS_REGION=us-east-1

# AWS credentials – generate these from IAM Console
# Use a dedicated IAM user with minimum required permissions
AWS_ACCESS_KEY_ID=your-access-key-here
AWS_SECRET_ACCESS_KEY=your-secret-key-here

# ========================================
# S3 BUCKETS
# ========================================

# Bucket for storing uploaded audio files (created manually or via AWS CLI)
# Bucket names must be globally unique – replace 'yourteamname' with your actual team identifier
S3_AUDIO_BUCKET=citadel-audio-yourteamname

# Bucket for storing generated PDF files
S3_PDFS_BUCKET=citadel-pdfs-yourteamname

# ========================================
# API GATEWAY ENDPOINTS
# ========================================

# Base URL of your deployed API Gateway
# Format: https://{api-id}.execute-api.{region}.amazonaws.com/{stage}
# Example: https://a1b2c3d4e5.execute-api.us-east-1.amazonaws.com/prod
API_BASE_URL=https://your-api-id.execute-api.us-east-1.amazonaws.com/prod

# Individual endpoint URLs (constructed from base)
TRANSCRIBE_API_URL=${API_BASE_URL}/transcribe
ANALYZE_API_URL=${API_BASE_URL}/analyze
GENERATE_API_URL=${API_BASE_URL}/generate

# ========================================
# FRONTEND (Vercel)
# ========================================

# Your deployed frontend URL (Vercel provides this)
# Example: https://citadel-ai.vercel.app
NEXT_PUBLIC_APP_URL=https://citadel-ai.vercel.app

# ========================================
# OPTIONAL SETTINGS
# ========================================

# Lambda function names (if you used different names)
TRANSCRIBE_FUNCTION_NAME=citadel-transcribe-processor
ANALYZE_FUNCTION_NAME=citadel-nova-analyzer
PDF_FUNCTION_NAME=citadel-pdf-generator

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
